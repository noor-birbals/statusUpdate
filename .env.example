# Atlassian OAuth app — create at https://developer.atlassian.com/console/myapps/
# Authorization: OAuth 2.0 (3LO), callback URL must match ATLASSIAN_REDIRECT_URI exactly
ATLASSIAN_CLIENT_ID=your_client_id
ATLASSIAN_CLIENT_SECRET=your_client_secret
ATLASSIAN_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Random secret for signing session cookies (use: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-long-random-string

# Production example:
# ATLASSIAN_REDIRECT_URI=http://your-server:7000/api/auth/callback

# Story points custom field ID (Micurato/Birbals use customfield_10032)
JIRA_STORY_POINTS_FIELD=customfield_10032
